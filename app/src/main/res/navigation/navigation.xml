<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/ticketListFragment">

    <fragment
        android:id="@+id/ticketListFragment"
        android:name="com.keerthana.ticketmateai.ui.tickets.TicketListFragment"
        android:label="Tickets"
        tools:layout="@layout/fragment_ticket_list" />

    <fragment
        android:id="@+id/ticketDetailFragment"
        android:name="com.keerthana.ticketmateai.ui.detail.TicketDetailFragment"
        android:label="Ticket Detail"
        tools:layout="@layout/fragment_ticket_detail">
        <argument
            android:name="ticketId"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>

    <fragment
        android:id="@+id/scriptGeneratorFragment"
        android:name="com.keerthana.ticketmateai.ui.script.ScriptGeneratorFragment"
        android:label="Script Generator"
        tools:layout="@layout/fragment_script_generator" />

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.keerthana.ticketmateai.ui.history.HistoryFragment"
        android:label="History"
        tools:layout="@layout/fragment_history" />

</navigation>